# dYdX API credentials
# Get these from: https://trade.dydx.exchange (Settings > API Keys)
DYDX_API_KEY=
DYDX_API_SECRET=
DYDX_API_PASSPHRASE=
DYDX_STARK_PRIVATE_KEY=
DYDX_POSITION_ID=

# Exchange host
# Mainnet: https://api.dydx.exchange
# Testnet: https://api.stage.dydx.exchange
DYDX_HOST=https://api.stage.dydx.exchange

# Market to trade
DYDX_MARKET=BTC-USD

# Market maker settings
BOT_ORDER_SIZE=0.001
BOT_MAX_INVENTORY=0.01
BOT_GAMMA=0.1
BOT_MIN_SPREAD_BPS=5.0
BOT_REFRESH_INTERVAL=10.0

# Risk limits
BOT_MAX_DRAWDOWN=0.10
BOT_MAX_EXPOSURE=50000

# Telegram alerts (optional)
# 1. Message @BotFather on Telegram -> /newbot -> copy the token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Find "chat":{"id":123456} -> that's your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Heartbeat interval in seconds (how often to send "I'm alive" to Telegram)
BOT_HEARTBEAT_INTERVAL=300
